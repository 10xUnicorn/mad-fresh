{
  "expo": {
    "name": "Mad Fresh Kitchen",
    "slug": "mad-fresh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "madfresh",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.madfresh.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR codes for rewards",
        "NSPhotoLibraryUsageDescription": "Used to upload your profile photo"
      }
    },
    "android": {
      "package": "com.madfresh.app",
      "adaptiveIcon": {
        "backgroundColor": "#3d6b2a",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf8f3"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf8f3",
          "image": "./assets/mad-fresh-logo.png",
          "imageWidth": 200
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3d6b2a"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.madfresh.app",
          "enableGooglePay": true
        }
      ]
    ]
  }
}
